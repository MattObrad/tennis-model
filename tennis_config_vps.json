  "data": {
    "db_path": "/home/picks/tennis.db",
    "alerts_db_path": "/home/picks/alerts.db",
    "sackmann_start_year": 2015,
    "train_cutoff": "2022-12-31",
    "validate_start": "2023-01-01",
    "validate_end":   "2024-12-31",
    "holdout_start":  "2025-01-01"
  },
  "vps": {
    "host": "localhost",
    "port": 5432,
    "database": "picksdb",
    "user": "picksuser",
    "password_env": "VPS_DB_PASSWORD"
  },
  "deploy": {
    "host": "198.199.77.143",
    "user": "picks",
    "remote_dir": "/home/picks"
  }
