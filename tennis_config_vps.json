{
  "_comment": "VPS-side config for ITF Women tennis model. Deployed as /home/picks/tennis_config.json",
  "_diff_from_local": "db_path and alerts_db_path point to VPS filesystem; vps.host is localhost",
  "model": {
    "name": "elo_v1.0",
    "version": "1.0",
    "k_factor": 32,
    "starting_elo": 1500,
    "elo_formula_scale": 400,
    "surface_weight": 1.0,
    "min_matches_for_surface_elo": 5
  },
  "betting": {
    "paper_mode": false,
    "min_edge": 0.08,
    "min_model_prob": 0.70,
    "min_career_matches": 10,
    "max_odds_american": 300
